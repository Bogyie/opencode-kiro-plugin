{
  "name": "@bogyie/opencode-kiro-plugin",
  "version": "0.2.7",
  "description": "OpenCode plugin for using Kiro as a provider adapter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "smoke:package": "npm run build && node scripts/smoke-package.mjs",
    "smoke:kiro": "npm run build && node scripts/real-kiro-smoke.mjs",
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "kiro",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bogyie/opencode-kiro-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/bogyie/opencode-kiro-plugin/issues"
  },
  "homepage": "https://github.com/bogyie/opencode-kiro-plugin#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@aws/codewhisperer-streaming-client": "^1.0.45",
    "@opencode-ai/plugin": "^1.15.11"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "bun-types": "^1.3.8",
    "typescript": "^5.9.0"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "auth",
      "config",
      "provider",
      "tool"
    ]
  }
}
